# Helm Environment Variables
# Copy this file to .env and fill in values

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
DEMO_MODE=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL everywhere (prod + CI + local dev). See keel/CLAUDE.md.
# Local one-time setup: brew services start postgresql@16 && createdb helm_dev
DATABASE_URL=postgres:///helm_dev

# Tasks app — required to load tasks/models and run tests against the tasks/ tree.
# See helm/CLAUDE.md "Work Management surface" + pre-deploy checklist.
HELM_TASKS_ENABLED=true

# Email
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=DockLabs <info@docklabs.ai>

# Suite SSO via Keel (leave unset for standalone mode + direct Microsoft SSO)
# KEEL_OIDC_CLIENT_ID=
# KEEL_OIDC_CLIENT_SECRET=
# KEEL_OIDC_ISSUER=https://keel.docklabs.ai

# Microsoft Entra ID (Azure AD) — used when OIDC not configured
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Suite-mode helm-feed aggregation (Helm pulls from peer products)
# HELM_FEED_API_KEY=

# Helm metrics canary (external poller bearer token; see keel.ops)
# HELM_METRICS_TOKEN=

# AI (project briefings, summarization)
# ANTHROPIC_API_KEY=
